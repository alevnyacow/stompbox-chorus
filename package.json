{
  "name": "@stompbox/chorus",
  "description": "Framework-agnostic plug-and-play repositories (in-memory and Prisma support out of the box).",
  "keywords": [
    "repository",
    "data layer",
    "data access layer",
    "DAL",
    "in-memory",
    "scaffolding"
  ],
  "version": "1.2.3",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/alevnyacow/stompbox-chorus.git"
  },
  "bin": {
    "chorus": "./bin/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib",
    "check": "biome check --write",
    "dev": "rslib --watch",
    "format": "biome format --write",
    "test": "rstest",
    "test:watch": "rstest --watch"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@rslib/core": "^0.21.2",
    "@rstest/adapter-rslib": "^0.2.2",
    "@rstest/core": "^0.9.7",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.5",
    "@types/node": "^24.12.2",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@stompbox/compressor": "^6.0.4",
    "zod": "^4.3.6"
  }
}
